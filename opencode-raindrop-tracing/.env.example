# The switch that actually turns on local tracing for the OpenCode plugin.
# Point it at your locally-running Raindrop Workshop daemon.
# (As of @raindrop-ai/opencode-plugin v0.0.12 the global raindrop.json is NOT
#  honored — this env var is the reliable trigger.)
RAINDROP_LOCAL_DEBUGGER="http://localhost:5899/v1/"

# Provider credentials for OpenCode (or use `opencode auth login` instead).
OPENAI_API_KEY="sk-..."
