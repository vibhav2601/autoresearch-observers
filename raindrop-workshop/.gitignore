# Root-level markdown (except README) — e.g. PLAN, CLAUDE; revisit when ready to version them
/*.md
!README.md

# Dependencies
node_modules/
*.lockb
package-lock.json

# TypeScript & Vite (root + app/)
dist/
*.tsbuildinfo

# Vite (test runner cache can live under node_modules; also ignore project-level cache)
.vite/

# Build artifacts (tsc, bundled UI, Node SEA — see scripts/build-sea.cjs)
build/
web-next/src/generated/install-script.ts
web-next/src/generated/web-assets.ts

# Generated by scripts/embed-skills.ts before `bun build --compile`.
# Source of truth is skills/<name>/SKILL.md; src/init-skills.ts reads
# those off disk in source mode and only imports this file in the
# compiled binary, so the checked-in copy is just build noise.
src/skills.compiled.ts

# Test & coverage
coverage/

# Environment & secrets
.env
.env.*
!.env.example

# Debug logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDEs
.idea/
*.swp
*.swo
*~

# Tooling caches
.eslintcache
.prettiercache

# Local worktrees (per CLAUDE.md § Parallel agents)
.worktrees/

# External repos cloned for local research
/external/

# Playwright artifacts (UI e2e)
app/test-results/
app/playwright-report/

# Isolated local Workshop DB / scratch (e.g. alternate PORT dogfooding)
.isolated/

# Playwright MCP scratch (page snapshots, console logs)
.playwright-mcp/

# Ad-hoc screenshots from manual browser testing
/workshop-*.png

.claude/
.codex/

# Local IDE wirings dropped by `raindrop install --local` during dev smoke
# tests against the workshop itself. Real customer projects DO check
# `.cursor/` in (it's how rules + MCP entries propagate to teammates);
# we ignore it here only because we test the installer in this very repo
# and don't want the resulting sandbox paths leaking into commits.
#
# Allow-list the Cursor cloud-agent environment config so it ships with the
# repo (mirror of .devin/blueprint.yml). Add new agent-config files here as
# needed; sandbox installer artifacts under .cursor/ stay ignored.
.cursor/*
!.cursor/environment.json
!.cursor/install.sh
!.cursor/README.md
